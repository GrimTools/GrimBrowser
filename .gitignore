# Secrets — never publish these
.env
*.env

# Dependencies
node_modules/

# Build output (huge — rebuilt with `npm run dist`)
dist/

# Installers — hosted on the website / GitHub Releases, not in the repo
website/*.exe
*Setup*.exe

# Tor: keep tor.exe (bundled so it just works), but drop the regenerated cache
tor/data/
**/desktop.ini

# Runtime / user data
*.log

# Editor / OS junk
.DS_Store
Thumbs.db

# Local dev config (not for the public repo)
.claude/

# Local Netlify folder
.netlify

# Personal deploy tool — local only, never publish
grim-deploy.ps1
Grim Deploy.bat
.grim-deploy-secret

# Installers — served from the website, far too big for git (GitHub caps at 100MB)
website/*.dmg
website/*.AppImage
website/*.blockmap
